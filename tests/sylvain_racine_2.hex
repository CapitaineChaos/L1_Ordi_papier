30 ; Adresse de départ
7C ; Longueur du programme

;@|  hexa  |   adresse   |  Mnémonique  |        Sémantique        | Commentaire
; ################################################################################
; #                          Algorithme de Babylone
; #            Extraire la racine d'un nombre avec la méthode de Héron v2
; # Auteur : Sylvain Maitre 24002886
; # Date   : 23/06/2026
; ################################################################################
; Babylone:
    49 72  ;    30 31    ; IN α     72  ; (N) ← Entrée             ; Saisie du nombre (N)
    00 07  ;    32 33    ; LOAD #   07  ; A ← 07                   ;
    48 73  ;    34 35    ; STORE α  73  ; (X) ← A                  ; X ← 7
    48 75  ;    36 37    ; STORE α  75  ; (Y) ← A                  ; Y ← 7
; Suite:
    40 74  ;    38 39    ; LOAD α   74  ; A ← (M)                  ;
    48 75  ;    3A 3B    ; STORE α  75  ; (Y) ← A                  ; Y ← M
    40 73  ;    3C 3D    ; LOAD α   73  ; A ← (X)                  ;
    48 74  ;    3E 3F    ; STORE α  74  ; (M) ← A                  ; M ← X
    48 89  ;    40 41    ; STORE α  89  ; (b) ← A                  ; b ← X
    40 72  ;    42 43    ; LOAD α   72  ; A ← (N)                  ;
    48 88  ;    44 45    ; STORE α  88  ; (a) ← A                  ; a ← N
    00 4C  ;    46 47    ; LOAD #   4C  ; A ← Retour1              ;
    48 AB  ;    48 49    ; STORE α  AB  ; (retdiv) ← A             ; Préparer le retour 1
    10 76  ;    4A 4B    ; JUMP α   76  ; PC ← Division            ; Appeler division()
; Retour1:                                                         ; Retour de l'appel de division
    40 73  ;    4C 4D    ; LOAD α   73  ; A ← (X)                  ;
    60 8A  ;    4E 4F    ; ADD α    8A  ; A ← A + (Q)              ;
    48 88  ;    50 51    ; STORE α  88  ; (a) ← A                  ; a ← N/X + X
    00 02  ;    52 53    ; LOAD #   02  ; A ← 02                   ; A ← 02
    48 89  ;    54 55    ; STORE α  89  ; (b) ← A                  ; b ← 02
    00 5C  ;    56 57    ; LOAD #   5C  ; A ← Retour2              ;
    48 AB  ;    58 59    ; STORE α  AB  ; (retdiv) ← A             ; Préparer le retour 2
    10 76  ;    5A 5B    ; JUMP α   76  ; PC ← Division            ; Appeler division()
; Retour2:                                                         ; Retour de l'appel de division
    40 8A  ;    5C 5D    ; LOAD α   8A  ; A ← (Q)                  ; Q = (N/X + X)/2
    48 73  ;    5E 5F    ; STORE α  73  ; (X) ← A                  ; X ← Q
    61 75  ;    60 61    ; SUB α    75  ; A ← A − (Y)              ;
    12 66  ;    62 63    ; BRZ α    66  ; si A=0 : PC ← Afficher   ; Si X = Y, aller à Afficher
    10 38  ;    64 65    ; JUMP α   38  ; PC ← Suite               ; Sinon, aller à Suite
; Afficher:
    40 73  ;    66 67    ; LOAD α   73  ; A ← (X)                  ;
    61 74  ;    68 69    ; SUB α    74  ; A ← A − (M)              ;
    11 6F  ;    6A 6B    ; BRN α    6F  ; si A<0 : PC ← Afficher_X ; Si X = Y, aller à Afficher_X
; Afficher_M:
    41 74  ;    6C 6D    ; OUT α    74  ; Sortie ← (M)             ; Afficher M
    FF     ;    6E       ; STOP         ; arrêt                    ;
; Afficher_X:
    41 73  ;    6F 70    ; OUT α    73  ; Sortie ← (X)             ; Afficher X
    FF     ;    71       ; STOP         ; arrêt                    ;
    00     ;    72       ; @var name=N                   (72) = 00 ; Entrée
    00     ;    73       ; @var name=X                   (73) = 00 ; Valeur en cours
    00     ;    74       ; @var name=M                   (74) = 00 ; Valeur précédente de X
    00     ;    75       ; @var name=Y                   (75) = 00 ; Valeur précédente de M
; ################################################################################
; #                  Sous programme de division euclidienne
; #      Les variables a et b constituent les entrées ; Q et R les sorties
; #                          Avec a = Q * b + R
; ################################################################################
; Division:
    00 00  ;    76 77    ; LOAD #   00  ; A ← 00                   ;
    48 8A  ;    78 79    ; STORE α  8A  ; (Q) ← A                  ; Q ← 0
    40 89  ;    7A 7B    ; LOAD α   89  ; A ← (b)                  ;
    12 AA  ;    7C 7D    ; BRZ α    AA  ; si A=0 : PC ← ret        ; Si b = 0, aller à ret
    40 88  ;    7E 7F    ; LOAD α   88  ; A ← (a)                  ;
    48 8B  ;    80 81    ; STORE α  8B  ; (R) ← A                  ; R ← a
; t1:
    40 8B  ;    82 83    ; LOAD α   8B  ; A ← (R)                  ;
    11 8C  ;    84 85    ; BRN α    8C  ; si A<0 : PC ← t2         ; Si R < 0, aller à t2
    10 92  ;    86 87    ; JUMP α   92  ; PC ← t3                  ; Sinon, aller à t3
    00     ;    88       ; @var name=a                   (88) = 00 ; Dividende (Entrée)
    00     ;    89       ; @var name=b                   (89) = 00 ; Diviseur (Entrée)
    00     ;    8A       ; @var name=Q                   (8A) = 00 ; Quotient (Sortie)
    00     ;    8B       ; @var name=R                   (8B) = 00 ; Reste (Sortie)
; t2:
    40 89  ;    8C 8D    ; LOAD α   89  ; A ← (b)                  ;
    11 96  ;    8E 8F    ; BRN α    96  ; si A<0 : PC ← t4         ; Si B < 0, aller à t4
    10 9C  ;    90 91    ; JUMP α   9C  ; PC ← tok                 ; Sinon, aller à tok
; t3:
    40 89  ;    92 93    ; LOAD α   89  ; A ← (b)                  ;
    11 AA  ;    94 95    ; BRN α    AA  ; si A<0 : PC ← ret        ; Si b < 0, aller à ret
; t4:
    40 8B  ;    96 97    ; LOAD α   8B  ; A ← (R)                  ;
    61 89  ;    98 99    ; SUB α    89  ; A ← A − (b)              ;
    11 AA  ;    9A 9B    ; BRN α    AA  ; si A<0 : PC ← ret        ; Si R - B < 0, aller à ret
; tok:
    40 8B  ;    9C 9D    ; LOAD α   8B  ; A ← (R)                  ;
    61 89  ;    9E 9F    ; SUB α    89  ; A ← A − (b)              ;
    48 8B  ;    A0 A1    ; STORE α  8B  ; (R) ← A                  ; R ← R - B
    40 8A  ;    A2 A3    ; LOAD α   8A  ; A ← (Q)                  ;
    20 01  ;    A4 A5    ; ADD #    01  ; A ← A + 01               ;
    48 8A  ;    A6 A7    ; STORE α  8A  ; (Q) ← A                  ; Q ← Q + 1
    10 82  ;    A8 A9    ; JUMP α   82  ; PC ← t1                  ; Aller à t1
; ret:
; @alias operande=retdiv
    10 00  ;    AA AB    ; JUMP α   00  ; PC ← 00                  ; Retour à l'envoyeur
